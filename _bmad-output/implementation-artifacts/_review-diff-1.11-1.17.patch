+.dice-chip { display: inline-flex; align-items: center; justify-content: center; min-width: 30px; min-height: 30px; padding: 0 0.4rem; margin: 0 0.15rem; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; font-weight: 700; cursor: pointer; }
+.dice-chip.sm { min-width: 24px; min-height: 24px; font-size: 0.75rem; cursor: default; }
+.ok { color: #39d98a; } .warn { color: #ff6b6b; }
+
+/* 近战/射击歧义 chips */
+.chips-ask { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; background: var(--panel); border: 1px solid var(--accent); border-radius: 6px; padding: 0.5rem 0.75rem; margin: 0.4rem 0; }
+
+/* 结果页（1.16） */
+.result-page { text-align: center; padding: 2rem 1rem; }
+.result-page .outcome { font-size: 1.2rem; margin: 1rem 0; }
+
+/* 规则查询（1.17） */
+.rules-query { width: 480px; }
+.rq-list { list-style: none; padding: 0; margin: 0.5rem 0; max-height: 50vh; overflow-y: auto; }
+.rq-item { padding: 0.4rem 0; border-bottom: 1px solid var(--border); }
+.rq-fields { font-size: 0.78rem; line-height: 1.5; }
+.rq-src { font-size: 0.72rem; font-style: italic; }
+
+/* 地形编辑器（1.12） */
+.terrain-editor h2 { margin: 0 0 0.3rem; font-size: 1.1rem; }
+.te-toolbar { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; margin: 0.4rem 0; }
+.te-sep { width: 1px; height: 24px; background: var(--border); display: inline-block; }
+.te-canvas { background: #0f1115; border: 1px solid var(--border); border-radius: 6px; touch-action: none; }
+
+/* 三栏布局 shell（1.13） */
+.play-view { display: flex; flex-direction: column; gap: 0.4rem; }
+.play-main { display: grid; grid-template-columns: minmax(0, 1fr) 22rem 18rem; gap: 0.6rem; align-items: start; }
+@media (max-width: 1280px) {
+  .play-main { grid-template-columns: 1fr; }
+  .play-right-col { order: 3; }
+}
+.play-right-col { display: flex; flex-direction: column; gap: 0.4rem; }
